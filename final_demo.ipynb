    "for name, results in agents.items():\n",
    "    # Exclude random since it is terrible\n",
    "    if name == \"Random\":\n",
    "        continue\n",
    "    # Get means for avg wait times per esi level\n",
    "    means = [results[\"avg_esi_waits\"][esi].mean() / 12 for esi in range(1, 6)]\n",
    "    ax.bar(x + i * bar_width, means, width=bar_width, label=name)\n",
    "    i += 1\n",
    "\n",
    "ax.set_title(\"Mean Max Wait Time by ESI Level (avg of 50 runs)\")\n",
    "ax.set_xlabel(\"ESI Level\")\n",
    "ax.set_ylabel(\"Wait Time (hours)\")\n",
    "ax.set_xticks(x + bar_width)  # center tick labels under the 3-bar groups\n",
    "ax.set_xticklabels(esi_levels)\n",
    "ax.legend()\n",
    "ax.grid(True, axis=\"y\", alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
