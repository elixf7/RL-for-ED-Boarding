   "source": [
    "# ED Boarding Project Final Report\n",
    "\n",
    "Trains a DQN agent on the Emergency Department simulation and compares it against the three baselines:\n",
    "\n",
    "- **Random**: picks a random action each step\n",
    "- **FCFS**: First Come First Served, admits the oldest patient first\n",
    "- **Acuity First**: always admits the highest acuity patient first\n",
    "- **DQN**: learned policy with Deep Q-Network"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-02",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Imports\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from ed_env import EmergencyDeptEnv, BED_CAPACITY, EPISODE_LENGTH\n",
    "from baselines import RandomAgent, FCFSAgent, AcuityFirstAgent\n",
    "from dqn_agent import DQNAgent, TARGET_UPDATE_FREQ"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-03",
   "metadata": {},
   "source": [
    "## Helper Functions\n",
    "\n",
    "`run_episode`: runs a 24-hour episode and returns per step metrics\n",
    "\n",
    "`run_agent`: runs an agent for multiple episodes and averages the results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-04",
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_episode(env, agent):\n",
    "    obs, _ = env.reset()\n",
    "\n",
    "    # Keep track of different metrics \n",
    "    rewards = []\n",
    "    queue_lengths = []\n",
    "    bed_occupancy = []\n",
    "    total_beds = sum(BED_CAPACITY.values())\n",
    "\n",
    "    # Store esi max wait times for analysis\n",
    "    esi_max_waits = {}\n",
    "    for esi in range(1, 6):\n",
    "        esi_max_waits[esi] = []\n",
    "\n",
    "    terminated = False\n",
    "    truncated = False\n",
    "    while not (terminated or truncated):\n",
    "        # RandomAgent doesn't take env as input, all others do\n",
    "        if isinstance(agent, RandomAgent):\n",
    "            action = agent.select_action()\n",
    "        else:\n",
    "            action = agent.select_action(env)\n",
    "\n",
    "        # Take a step in environment with action chosen\n",
    "        obs, reward, terminated, truncated, info = env.step(action)\n",
    "\n",
    "        # Keep track of rewards and queue length\n",
    "        rewards.append(reward)\n",
    "        queue_lengths.append(info[\"queue_length\"])\n",
    "\n",
    "        # Calulate bed occupancy which is patients in beds / total beds\n",
    "        patients_in_beds = 0\n",
    "        for b in env.beds:\n",
    "            patients_in_beds += len(env.beds[b])\n",
    "        bed_occupancy.append(patients_in_beds / total_beds)\n",
    "\n",
    "        # Get max wait times for each ESI level\n",
    "        for esi in range(1, 6):\n",
    "            waits = []\n",
    "            for p in env.waiting_queue:\n",
    "                if p.esi == esi:\n",
    "                    waits.append(p.steps_waiting(env.current_step))\n",
    "            esi_max_waits[esi].append(max(waits) if waits else 0)\n",
    "\n",
    "    # Return all metrics and rewards for evaluation\n",
    "    return {\n",
    "        \"rewards\": rewards,\n",
    "        \"queue_lengths\": queue_lengths,\n",
    "        \"bed_occupancy\": bed_occupancy,\n",
    "        \"esi_max_waits\": esi_max_waits,\n",
    "        \"total_discharged\": info[\"total_discharged\"],\n",
    "        \"total_lwbs\": info[\"total_lwbs\"],\n",
    "    }\n",
    "\n",
    "# Runs an agent for specified number of episodes\n",
    "def run_agent(agent, num_episodes=50):\n",
    "    # Initialize ED environment\n",
    "    env = EmergencyDeptEnv()\n",
    "    # Call run_episode num_episodes times\n",
    "    all_episodes = []\n",
    "    for _ in range(num_episodes):\n",
    "        all_episodes.append(run_episode(env, agent))\n",
    "\n",
    "    # Calculates the average esi wait times\n",
    "    avg_esi_waits = {}\n",
    "    for esi in range(1, 6):\n",
    "        esi_data = [ep[\"esi_max_waits\"][esi] for ep in all_episodes]\n",
    "        avg_esi_waits[esi] = np.mean(esi_data, axis=0)\n",
    "\n",
    "    # Returns averaged results across all episodes\n",
    "    return {\n",
    "        \"avg_rewards\": np.mean([ep[\"rewards\"] for ep in all_episodes], axis=0),\n",
    "        \"avg_queue\": np.mean([ep[\"queue_lengths\"] for ep in all_episodes], axis=0),\n",
    "        \"avg_occupancy\": np.mean([ep[\"bed_occupancy\"] for ep in all_episodes], axis=0),\n",
    "        \"avg_esi_waits\": avg_esi_waits,\n",
    "        \"mean_discharged\": np.mean([ep[\"total_discharged\"] for ep in all_episodes]),\n",
    "        \"mean_lwbs\": np.mean([ep[\"total_lwbs\"] for ep in all_episodes]),\n",
    "    }"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-05",
   "metadata": {},
   "source": [
    "## Training\n",
    "\n",
    "Train the DQN for N episodes. Each episode is 288 steps (24 hours at 5-min intervals).\n",
    "Progress is printed every 50 episodes with a mean reward."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-06",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
