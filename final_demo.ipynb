   "source": [
    "# Window for rolling avg\n",
    "window = 20\n",
    "smoothed = np.convolve(episode_rewards, np.ones(window) / window, mode='valid')\n",
    "n = len(episode_rewards)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "# Plot individal raw rewards\n",
    "ax.plot(episode_rewards, alpha=0.25, color='steelblue', label='Raw reward')\n",
    "# Plot the rolling avg line\n",
    "ax.plot(range(window - 1, n), smoothed, color='steelblue', linewidth=2, label='20-ep rolling avg')\n",
    "\n",
    "ax.set_title(\"DQN Training Curve\")\n",
    "ax.set_xlabel(\"Episode\")\n",
    "ax.set_ylabel(\"Total Reward\")\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
