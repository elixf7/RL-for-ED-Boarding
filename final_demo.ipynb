    "# Plot 1: Cumulative reward over 24-hour episode\n",
    "\n",
    "# Get steps for episode length\n",
    "steps = np.arange(1, EPISODE_LENGTH + 1)\n",
    "\n",
    "# Convert steps to hours\n",
    "# Starts at 8 AM, 12 steps per hour\n",
    "def step_to_hour(step):\n",
    "    return (8 + step / 12) % 24\n",
    "\n",
    "# x-axis label steps\n",
    "x_label_steps = [0, 48, 96, 144, 192, 240, 288]\n",
    "# Formal labels to be times\n",
    "x_labels = [f\"{int(step_to_hour(s)):02d}:00\" for s in x_label_steps]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "for name, results in agents.items():\n",
    "    # Exclude Random since it is terrible\n",
    "    if name == \"Random\":\n",
    "        continue\n",
    "    # Get cumulative reward from results and plot\n",
    "    cumulative = np.cumsum(results[\"avg_rewards\"])\n",
    "    ax.plot(steps, cumulative, label=name, linewidth=2)\n",
    "\n",
    "ax.set_title(\"Cumulative Reward Over a 24-Hour Episode (avg of 50 runs)\")\n",
    "ax.set_xlabel(\"Time of Day\")\n",
    "ax.set_ylabel(\"Cumulative Reward\")\n",
    "ax.set_xticks(np.linspace(1, EPISODE_LENGTH, 7))\n",
    "ax.set_xticklabels(x_labels)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
