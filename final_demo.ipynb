    "# Plot 3: Discharges vs LWBS penalty \n",
    "# Each agent gets two bars: one for mean discharges and one for mean LWBS\n",
    "\n",
    "# Get agent names, discharges, and LWBS penalties\n",
    "agent_names = list(agents.keys())\n",
    "discharges = [agents[n][\"mean_discharged\"] for n in agent_names]\n",
    "lwbs = [agents[n][\"mean_lwbs\"] for n in agent_names]\n",
    "\n",
    "# Define color scheme, bar width, and x axis data\n",
    "x = np.arange(len(agent_names))\n",
    "bar_width = 0.35\n",
    "colors_d = [ \"#e15759\", \"#4e79a7\", \"#f28e2b\", \"#59a14f\"]\n",
    "colors_l = [ \"#ffadad\", \"#a0c4ff\", \"#ffd6a5\", \"#b9fbc0\"]\n",
    "\n",
    "# Plot each bar\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "ax.bar(x - bar_width / 2, discharges, width=bar_width, color=colors_d, label=\"Mean Discharges\")\n",
    "ax.bar(x + bar_width / 2, [-l for l in lwbs], width=bar_width, color=colors_l, label=\"Mean LWBS\")\n",
    "\n",
    "ax.axhline(0, color=\"black\", linewidth=0.8)\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(agent_names)\n",
    "ax.set_ylabel(\"Patients per Episode\")\n",
    "ax.set_title(\"Discharges vs. LWBS per Episode (avg of 50 runs)\\nHigher discharges = better  |  Less negative LWBS = better\")\n",
    "ax.legend()\n",
    "ax.grid(True, axis=\"y\", alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
