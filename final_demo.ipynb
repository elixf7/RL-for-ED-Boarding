    "# Wrapper class to I can call run_agent()\n",
    "class TrainedDQNAgent:\n",
    "    def __init__(self, dqn_agent):\n",
    "        self.agent = dqn_agent\n",
    "\n",
    "    def select_action(self, env):\n",
    "        obs = env._get_obs()\n",
    "        # Epsilon is 0.0 at evaluation time\n",
    "        return self.agent.select_action(obs, epsilon=0.0)\n",
    "\n",
    "\n",
    "print(\"Running Random Agent\")\n",
    "random_results = run_agent(RandomAgent(EmergencyDeptEnv().action_space))\n",
    "\n",
    "print(\"Running FCFS Agent\")\n",
    "fcfs_results = run_agent(FCFSAgent())\n",
    "\n",
    "print(\"Running Acuity First Agent\")\n",
    "acuity_results = run_agent(AcuityFirstAgent())\n",
    "\n",
    "print(\"Running DQN Agent\")\n",
    "dqn_results = run_agent(TrainedDQNAgent(agent))\n",
    "\n",
    "print(\"\\nDone.\")\n",
    "\n",
    "# Store agent results in dictionary\n",
    "agents = {\n",
    "    \"Random\": random_results,\n",
    "    \"FCFS\": fcfs_results,\n",
    "    \"Acuity First\": acuity_results,\n",
    "    \"DQN\": dqn_results,\n",
    "}"
   ]
  },
