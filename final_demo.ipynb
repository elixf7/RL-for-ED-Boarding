      "Episode 50/600 | Avg Reward (last 50): -15907.0 | ε: 0.905\n",
      "Episode 100/600 | Avg Reward (last 50): -14267.3 | ε: 0.810\n",
      "Episode 150/600 | Avg Reward (last 50): -13361.4 | ε: 0.715\n",
      "Episode 200/600 | Avg Reward (last 50): -10968.9 | ε: 0.620\n",
      "Episode 250/600 | Avg Reward (last 50): -10304.4 | ε: 0.525\n",
      "Episode 300/600 | Avg Reward (last 50): -9462.8 | ε: 0.430\n",
      "Episode 350/600 | Avg Reward (last 50): -8821.3 | ε: 0.335\n",
      "Episode 400/600 | Avg Reward (last 50): -8192.6 | ε: 0.240\n",
      "Episode 450/600 | Avg Reward (last 50): -7636.1 | ε: 0.145\n",
      "Episode 500/600 | Avg Reward (last 50): -7513.1 | ε: 0.050\n",
      "Episode 550/600 | Avg Reward (last 50): -6458.8 | ε: 0.050\n",
      "Episode 600/600 | Avg Reward (last 50): -6803.6 | ε: 0.050\n",
      "Training complete.\n",
      "Weights and rewards saved.\n"
     ]
    }
   ],
   "source": [
    "# Set up constants, environment, and agent type\n",
    "N_EPISODES = 600\n",
    "env = EmergencyDeptEnv()\n",
    "agent = DQNAgent()\n",
    "episode_rewards = []\n",
    "\n",
    "# Loop through number of episodes\n",
    "for episode in range(N_EPISODES):\n",
    "    obs, _ = env.reset()\n",
    "    done = False\n",
    "    total_reward = 0.0\n",
    "\n",
    "    # Loop until episode is over\n",
    "    while not done:\n",
    "        # Select action\n",
    "        action = agent.select_action(obs)\n",
    "        next_obs, reward, terminated, truncated, info = env.step(action)\n",
    "        done = terminated or truncated\n",
    "\n",
    "        # Stores the results of that action in Replay Buffer\n",
    "        agent.store(obs, action, reward, next_obs, done)\n",
    "        agent.update()\n",
    "\n",
    "        # Synch target network with online network if number of gradient steps is reached\n",
    "        if agent.steps_done > 0 and agent.steps_done % TARGET_UPDATE_FREQ == 0:\n",
    "            agent.sync_target()\n",
    "\n",
    "        obs = next_obs\n",
    "        # Track total reward\n",
    "        total_reward += reward\n",
    "\n",
    "    # Decay epsilon as training continues\n",
    "    agent.decay_epsilon()\n",
    "    episode_rewards.append(total_reward)\n",
    "\n",
    "    # Print average reward for past 50 episdoes to keep track of training progress\n",
    "    if (episode + 1) % 50 == 0:\n",
    "        avg_50 = np.mean(episode_rewards[-50:])\n",
    "        print(f\"Episode {episode + 1}/{N_EPISODES} | Avg Reward (last 50): {avg_50:.1f} | ε: {agent.epsilon:.3f}\")\n",
    "\n",
    "print(\"Training complete.\")\n",
    "agent.save()\n",
    "np.save(\"episode_rewards.npy\", np.array(episode_rewards))\n",
    "print(\"Weights and rewards saved.\")"
   ]
  },
